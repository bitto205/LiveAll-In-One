{
  "id": "default",
  "name": "默认",
  "version": 1,
  "tool": "danmu",
  "surfaces": ["bubble", "gift_bubble"],
  "metrics": {
    "fade_w": 22,
    "pad_h": 12,
    "pad_v": 7,
    "gift_icon_size": 32,
    "gift_icon_gap": 8
  },
  "colors": {
    "user": [255, 255, 255, 200],
    "body": [255, 255, 255, 255],
    "gradient_mid": [0, 0, 0, 128],
    "gradient_edge": [0, 0, 0, 0]
  },
  "styles": {
    "user": "color: rgba(255,255,255,200); background: transparent;",
    "body": "color: rgba(255,255,255,255); background: transparent;",
    "suffix": "color: rgba(255,255,255,200); background: transparent;"
  },
  "layouts": {
    "bubble": {
      "spacing": 2,
      "row_align": "center",
      "roles": {
        "user": {
          "pixel_size": 11,
          "align": "center",
          "style_extra": "font-weight:600;"
        },
        "body": {
          "pixel_size": 13,
          "align": "center",
          "word_wrap": true,
          "min_chars": 4,
          "max_chars": 16,
          "slack_px": 2
        }
      }
    },
    "gift_bubble": {
      "spacing": 2,
      "text_slack": 4,
      "roles": {
        "user": {
          "pixel_size": 11,
          "align": "left",
          "style_extra": "font-weight:600;"
        },
        "body": {
          "pixel_size": 13,
          "align": "left"
        },
        "suffix": {
          "pixel_size": 11,
          "align": "left"
        }
      }
    }
  }
}
